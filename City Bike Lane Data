/*
Provide a list of all the bike lanes. For each lane, include the following:

- Average safety rating
- Recommendation to "Remove" when avg rating is below 2.5
- Recommendation for "Leave As-Is" when avg rating is above 4
- Recommendation for "Improvements Needed" on all other lanes

- Recommendation label (Remove = <2.5, Leave As-Is = >4, Improvements Needed = all other lanes)
*/ 

select
    street,
    avg(safetyrating) over (
        partition by street
    ) as avg_safety_rating,
    case
        when avg(safetyrating) over (
            partition by safetyrating) >= 4
        then 'Leave As-Is'
        when avg(safetyrating) over (
            partition by safetyrating) < 2.5 
        then 'Remove'
        else 'Improvements Needed'
    end as recommendation
from city_bike_lanes

order by
    case
        when recommendation = 'Remove' then 1
        when recommendation = 'Improvements Needed' then 2
        when recommendation = 'Leave As-Is' then 3
    end;
